#!/bin/bash
# Privileged backend for automatic LinuxBook-Air Thunderbolt power control.
set -euo pipefail

readonly STATE_DIR="/run/linuxbook-air"
readonly STATE_FILE="${STATE_DIR}/thunderbolt-enabled"
readonly STATE_EVENT_FILE="${STATE_DIR}/thunderbolt-state-changed"
readonly SUSPEND_FILE="${STATE_DIR}/thunderbolt-suspending"
readonly LEGACY_RESTART_FILE="${STATE_DIR}/thunderbolt-restart-required"
readonly CONTROL_LOCK="${STATE_DIR}/thunderbolt-control.lock"
readonly POWERDOWN_LOCK="/run/tb-powerdown.lock"
readonly POWERDOWN_HELPER="/usr/libexec/tb-powerdown.sh"
readonly LOG_TAG="linuxbook-air-thunderbolt"

log_event() {
    local priority="$1"
    shift
    logger -p "$priority" -t "$LOG_TAG" -- "$*" || true
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        printf 'This operation requires administrator privileges.\n' >&2
        exit 1
    fi
}

notify_state_change() {
    install -d -m 0755 "$STATE_DIR"
    touch "$STATE_EVENT_FILE"
}

is_falcon_ridge_device() {
    local path="$1"
    local vendor device

    [[ -r "${path}/vendor" && -r "${path}/device" ]] || return 1
    read -r vendor < "${path}/vendor"
    read -r device < "${path}/device"
    [[ "$vendor" == "0x8086" && ( "$device" == "0x156a" || "$device" == "0x156b" ) ]]
}

falcon_ridge_present() {
    local path

    for path in /sys/bus/pci/devices/*; do
        if is_falcon_ridge_device "$path"; then
            return 0
        fi
    done
    return 1
}

nhi_present() {
    local path

    for path in /sys/bus/pci/devices/*; do
        if is_falcon_ridge_device "$path" && [[ $(<"${path}/device") == "0x156a" ]]; then
            return 0
        fi
    done
    return 1
}

# The built-in Falcon Ridge functions stop at 06:03.0. Anything below that
# bridge is an external PCIe-tunnelled Thunderbolt device. Matching topology
# instead of a vendor/device ID supports Ethernet, storage, docks, and other
# adapters without maintaining an allow-list.
external_device_present() {
    local path real_path

    for path in /sys/bus/pci/devices/*; do
        [[ -e "$path" ]] || continue
        real_path=$(readlink -f "$path")
        if [[ "$real_path" == *"/0000:06:03.0/"* ]]; then
            return 0
        fi
    done
    return 1
}

thunderbolt_pci_addresses() {
    local path real_path addresses=""

    for path in /sys/bus/pci/devices/*; do
        [[ -e "$path" ]] || continue
        real_path=$(readlink -f "$path")
        if [[ "$real_path" == *"/0000:05:00.0"* ]]; then
            addresses+="${addresses:+,}$(basename "$path")"
        fi
    done
    printf '%s' "${addresses:-none}"
}

log_snapshot() {
    local stage="$1" marker="absent" module="unloaded" nhi="absent" external="absent" hierarchy="absent"

    [[ -e "$STATE_FILE" ]] && marker="present"
    lsmod | grep -q '^thunderbolt ' && module="loaded"
    nhi_present && nhi="present"
    external_device_present && external="present"
    falcon_ridge_present && hierarchy="present"
    log_event daemon.info \
        "stage=$stage marker=$marker module=$module nhi=$nhi external=$external hierarchy=$hierarchy pci_devices=$(thunderbolt_pci_addresses)"
}

thunderbolt_storage_present() {
    local block target

    for block in /sys/class/block/*; do
        [[ -e "$block" ]] || continue
        target=$(readlink -f "$block")
        if [[ "$target" == *"/0000:05:00.0/"* ]]; then
            log_event daemon.warning \
                "action=powerdown safety-check=failed block_device=$(basename "$block")"
            return 0
        fi
    done
    return 1
}

show_status() {
    if [[ -e "$STATE_FILE" ]] && external_device_present; then
        printf 'enabled\n'
    elif [[ -e "$STATE_FILE" ]]; then
        printf 'ready\n'
    elif falcon_ridge_present; then
        printf 'powerdown-incomplete\n'
    else
        printf 'disabled\n'
    fi
}

set_thunderbolt_tree_power_on() {
    local path real_path

    for path in /sys/bus/pci/devices/*; do
        [[ -e "$path" ]] || continue
        real_path=$(readlink -f "$path")
        if [[ "$real_path" == *"/0000:05:00.0"* && -w "${path}/power/control" ]]; then
            printf 'on\n' > "${path}/power/control"
            log_event daemon.info \
                "action=activate stage=runtime-pm device=$(basename "$path") control=on"
        fi
    done
}

# This deliberately does almost no work: it runs directly from udev so the
# marker reaches an already-running power-down job before that job removes the
# bridge. Slow work is delegated to the systemd hotplug service.
claim_hotplug() {
    require_root
    install -d -m 0755 "$STATE_DIR"

    if [[ -e "$SUSPEND_FILE" ]]; then
        log_event daemon.info "action=hotplug-claim result=skipped reason=suspend-in-progress"
        return 0
    fi

    rm -f "$LEGACY_RESTART_FILE"
    if [[ ! -e "$STATE_FILE" ]]; then
        : > "$STATE_FILE"
        chmod 0644 "$STATE_FILE"
        log_event daemon.notice "action=hotplug-claim result=success marker=created"
    else
        log_event daemon.info "action=hotplug-claim result=success marker=already-present"
    fi
    notify_state_change
}

# PCI removal does not alter the active session. It only wakes the GNOME
# indicator so it can report that the external adapter is no longer present.
notify_hotplug_change() {
    require_root
    notify_state_change
}

activate_hotplug() {
    local failed=0

    if [[ -e "$SUSPEND_FILE" || ! -e "$STATE_FILE" ]]; then
        log_event daemon.info "action=activate result=skipped reason=not-claimed"
        return 0
    fi

    log_event daemon.notice "action=activate stage=start"
    exec 8> "$POWERDOWN_LOCK"
    flock 8
    log_event daemon.info "action=activate stage=powerdown-lock-acquired"

    # If teardown won the race there is no session to keep active. Returning
    # to the powered-down state lets a later physical replug try again.
    if ! external_device_present; then
        rm -f "$STATE_FILE"
        notify_state_change
        flock -u 8
        log_event daemon.warning "action=activate result=missed reason=external-device-disappeared"
        "$POWERDOWN_HELPER" || true
        return 0
    fi

    if ! modprobe thunderbolt; then
        log_event daemon.err "action=activate result=failed reason=module-load"
        failed=1
    elif ! set_thunderbolt_tree_power_on; then
        log_event daemon.err "action=activate result=failed reason=runtime-pm"
        failed=1
    fi

    if (( failed )); then
        rm -f "$STATE_FILE"
        notify_state_change
        flock -u 8
        "$POWERDOWN_HELPER" || true
        return 1
    fi

    flock -u 8
    notify_state_change
    log_snapshot "activate-after"
    log_event daemon.notice "action=activate result=success lifetime=until-suspend-or-reboot"
}

power_down_thunderbolt() {
    local reason="$1"

    log_event daemon.notice "action=powerdown-request reason=$reason stage=start"
    log_snapshot "powerdown-request-before"

    if thunderbolt_storage_present; then
        log_event daemon.err "action=powerdown-request reason=$reason result=refused reason_detail=thunderbolt-storage-present"
        printf 'Disconnect all Thunderbolt storage devices before suspending.\n' >&2
        return 1
    fi

    if lsmod | grep -q '^thunderbolt_net '; then
        if modprobe -r thunderbolt_net; then
            log_event daemon.info "action=powerdown-request stage=module-removed module=thunderbolt_net"
        else
            log_event daemon.warning "action=powerdown-request stage=module-remove-failed module=thunderbolt_net"
        fi
    fi
    if lsmod | grep -q '^thunderbolt '; then
        if ! modprobe -r thunderbolt; then
            log_event daemon.err "action=powerdown-request result=failed reason=module-remove module=thunderbolt"
            return 1
        fi
        log_event daemon.info "action=powerdown-request stage=module-removed module=thunderbolt"
    fi

    rm -f "$STATE_FILE" "$LEGACY_RESTART_FILE"
    notify_state_change
    "$POWERDOWN_HELPER"

    if falcon_ridge_present; then
        log_event daemon.err "action=powerdown-request reason=$reason result=failed reason_detail=pci-hierarchy-still-present"
        log_snapshot "powerdown-request-incomplete"
        return 1
    fi

    notify_state_change
    log_snapshot "powerdown-request-after"
    log_event daemon.notice "action=powerdown-request reason=$reason result=success"
}

prepare_suspend() {
    : > "$SUSPEND_FILE"
    chmod 0644 "$SUSPEND_FILE"
    notify_state_change
    log_event daemon.notice "action=prepare-suspend stage=start"

    if [[ -e "$STATE_FILE" ]] || lsmod | grep -q '^thunderbolt ' || falcon_ridge_present; then
        if ! power_down_thunderbolt suspend; then
            rm -f "$SUSPEND_FILE"
            notify_state_change
            log_event daemon.err "action=prepare-suspend result=failed"
            return 1
        fi
    else
        log_event daemon.info "action=prepare-suspend result=success reason=already-powered-down"
    fi
}

resume_from_suspend() {
    rm -f "$SUSPEND_FILE"
    notify_state_change
    log_event daemon.notice "action=resume stage=start"

    # A connected adapter may have re-enumerated during resume while claims
    # were suppressed. Reclaim it here; otherwise remain at maximum saving and
    # wait for the next physical plug event.
    if external_device_present; then
        : > "$STATE_FILE"
        chmod 0644 "$STATE_FILE"
        notify_state_change
        log_event daemon.notice "action=resume stage=external-device-present result=reclaiming"
        activate_hotplug
    else
        log_event daemon.notice "action=resume result=powered-down wait_for_hotplug=yes"
    fi
}

case "${1:-}" in
    status)
        show_status
        ;;
    hotplug-claim)
        claim_hotplug
        ;;
    hotplug-notify)
        notify_hotplug_change
        ;;
    hotplug-activate|prepare-suspend|resume)
        require_root
        install -d -m 0755 "$STATE_DIR"
        exec 9> "$CONTROL_LOCK"
        flock 9
        log_event daemon.info "action=$1 stage=control-lock-acquired uid=$EUID"
        case "$1" in
            hotplug-activate) activate_hotplug ;;
            prepare-suspend) prepare_suspend ;;
            resume) resume_from_suspend ;;
        esac
        ;;
    *)
        printf 'Usage: %s {status|hotplug-claim|hotplug-notify|hotplug-activate|prepare-suspend|resume}\n' "$0" >&2
        exit 2
        ;;
esac
