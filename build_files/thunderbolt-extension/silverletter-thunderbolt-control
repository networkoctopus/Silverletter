#!/bin/bash
# Privileged backend for manual, boot-scoped Thunderbolt enablement.
set -euo pipefail

readonly STATE_DIR="/run/silverletter"
readonly CONTROL_LOCK="${STATE_DIR}/thunderbolt-control.lock"
readonly POWERDOWN_LOCK="/run/tb-powerdown.lock"
readonly POWERDOWN_HELPER="/usr/libexec/tb-powerdown.sh"
readonly RUNTIME_RULE_DIR="/run/udev/rules.d"
readonly POWERDOWN_MASK="${RUNTIME_RULE_DIR}/99-thunderbolt-pm.rules"
readonly LOG_TAG="silverletter-thunderbolt"

log_event() {
    local priority="$1"
    shift
    logger -p "$priority" -t "$LOG_TAG" -- "$*" || true
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        printf 'This operation requires administrator privileges.\n' >&2
        exit 1
    fi
}

nhi_present() {
    [[ -e /sys/bus/pci/devices/0000:07:00.0 ]]
}

session_enabled() {
    [[ -L "$POWERDOWN_MASK" &&
       "$(readlink "$POWERDOWN_MASK")" == "/dev/null" ]]
}

show_status() {
    if session_enabled; then
        if nhi_present; then
            printf 'active\n'
        else
            printf 'armed\n'
        fi
    else
        printf 'disabled\n'
    fi
}

mask_powerdown_rule() {
    install -d -m 0755 "$STATE_DIR" "$RUNTIME_RULE_DIR"

    # A same-named /dev/null link in /run overrides the image's boot
    # power-down rule until /run is cleared by the next reboot.
    ln -sfn /dev/null "$POWERDOWN_MASK"

    udevadm control --reload-rules
    log_event daemon.info "action=enable stage=powerdown-rule-masked lifetime=until-reboot"
}

remove_powerdown_mask() {
    rm -f "$POWERDOWN_MASK"
    udevadm control --reload-rules || true
}

enable_thunderbolt() {
    local attempt powerdown_lock_acquired=0

    rollback_enable() {
        local status=$?
        trap - ERR
        log_event daemon.err "action=enable result=failed exit_status=$status"
        remove_powerdown_mask
        if (( powerdown_lock_acquired )); then
            flock -u 8 || true
        fi
        modprobe -r thunderbolt 2>/dev/null || true
        "$POWERDOWN_HELPER" || true
        exit "$status"
    }
    trap rollback_enable ERR

    log_event daemon.notice "action=enable stage=start lifetime=until-reboot"
    mask_powerdown_rule

    # Let every udev job that was queued under the image rule finish. The
    # power-down helper is deliberately not cancellable, so manual activation
    # always starts from the same fully removed PCI state.
    if ! udevadm settle --timeout=30; then
        printf 'Timed out waiting for the boot Thunderbolt power-down to finish.\n' >&2
        return 1
    fi
    log_event daemon.info "action=enable stage=boot-powerdown-settled"

    # Serialize with the helper as a final guard before PCI rescan.
    exec 8> "$POWERDOWN_LOCK"
    flock 8
    powerdown_lock_acquired=1
    log_event daemon.info "action=enable stage=powerdown-lock-acquired"

    modprobe thunderbolt
    log_event daemon.info "action=enable stage=module-loaded module=thunderbolt"

    printf '1\n' > /sys/bus/pci/rescan
    log_event daemon.info "action=enable stage=pci-rescan"
    udevadm settle --timeout=10 || true

    for attempt in {1..20}; do
        if nhi_present; then
            break
        fi
        sleep 0.5
    done

    if ! nhi_present; then
        # Falcon Ridge may not wake from its removed low-power state until it
        # sees a new physical hot-plug edge. Keep this boot-scoped session
        # armed and let a disconnect/reconnect perform the safe hardware wake.
        flock -u 8
        powerdown_lock_acquired=0
        trap - ERR
        log_event daemon.notice \
            "action=enable result=success state=armed controller=absent reconnect_required=yes lifetime=until-reboot"
        printf 'armed\n'
        return 0
    fi

    flock -u 8
    powerdown_lock_acquired=0
    trap - ERR
    log_event daemon.notice \
        "action=enable result=success state=active controller=0000:07:00.0 lifetime=until-reboot"
    printf 'active\n'
}

case "${1:-}" in
    status)
        show_status
        ;;
    enable)
        require_root
        install -d -m 0755 "$STATE_DIR"
        exec 9> "$CONTROL_LOCK"
        flock 9
        enable_thunderbolt
        ;;
    *)
        printf 'Usage: %s {status|enable}\n' "$0" >&2
        exit 2
        ;;
esac
