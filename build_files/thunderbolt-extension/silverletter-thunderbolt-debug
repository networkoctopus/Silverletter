#!/bin/bash
# Guided, boot-scoped diagnostics for the MacBook Air Falcon Ridge controller.
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: sudo silverletter-thunderbolt-debug --preset=1|2|3 [--scenario=all|hotplug|suspend]

Run each preset after a fresh reboot. The tool avoids repeated lspci access,
records kernel, udev, systemd and sysfs events, and guides physical actions.
EOF
}

PRESET=""
SCENARIO="all"
for argument in "$@"; do
    case "$argument" in
        --preset=*) PRESET="${argument#*=}" ;;
        --scenario=*) SCENARIO="${argument#*=}" ;;
        -h|--help) usage; exit 0 ;;
        *) printf 'Unknown argument: %s\n' "$argument" >&2; usage >&2; exit 2 ;;
    esac
done

if [[ $EUID -ne 0 ]]; then
    printf 'Run this command with sudo.\n' >&2
    exit 1
fi
if [[ ! -t 0 ]]; then
    printf 'This guided test requires an interactive terminal.\n' >&2
    exit 1
fi
if [[ ! "$SCENARIO" =~ ^(all|hotplug|suspend)$ ]]; then
    printf 'Unknown scenario: %s\n' "$SCENARIO" >&2
    usage >&2
    exit 2
fi

# Presets only change how long the diagnostic observes production behaviour.
# They never change activation, runtime-PM, or PCI-removal timing.
case "$PRESET" in
    1)
        CONNECT_TIMEOUT=90
        CONNECTION_HOLD=15
        DISCONNECT_TIMEOUT=180
        ;;
    2)
        CONNECT_TIMEOUT=180
        CONNECTION_HOLD=30
        DISCONNECT_TIMEOUT=240
        ;;
    3)
        CONNECT_TIMEOUT=300
        CONNECTION_HOLD=60
        DISCONNECT_TIMEOUT=300
        ;;
    *)
        printf 'Choose --preset=1, --preset=2, or --preset=3.\n' >&2
        exit 2
        ;;
esac

readonly STATE_DIR="/run/silverletter"
readonly CONFIG_FILE="${STATE_DIR}/thunderbolt-debug.conf"
readonly LOCK_FILE="${STATE_DIR}/thunderbolt-debug.lock"
readonly LOG_DIR="/var/log/silverletter/thunderbolt-debug"
readonly PERSIST_DIR="/var/lib/silverletter"
readonly LAST_LOG_FILE="${PERSIST_DIR}/thunderbolt-debug-last-log"
readonly BOOT_ID="$(< /proc/sys/kernel/random/boot_id)"
readonly START_STAMP="$(date +%Y%m%d-%H%M%S)"
readonly RUN_ID="${BOOT_ID%%-*}-preset${PRESET}-${START_STAMP}"
readonly LOG_FILE="${LOG_DIR}/${RUN_ID}.log"
RECOVERED_LOG=""

install -d -m 0755 "$STATE_DIR" "$LOG_DIR" "$PERSIST_DIR"
exec 9> "$LOCK_FILE"
if ! flock -n 9; then
    printf 'Another Thunderbolt debug session is already running.\n' >&2
    exit 1
fi

recover_previous_run() {
    local previous pstore_file

    [[ -r "$LAST_LOG_FILE" ]] || return 0
    read -r previous < "$LAST_LOG_FILE" || return 0
    [[ -f "$previous" ]] || return 0
    if grep -Eq 'result=(completed|stopped)' "$previous"; then
        return 0
    fi

    {
        printf '\n[recovery] realtime=%s previous_run_ended_without_clean_exit=yes\n' "$(date --iso-8601=ns)"
        printf '[recovery] previous-boot kernel journal follows\n'
        journalctl -b -1 -k -o short-monotonic --no-pager 2>&1 || true
        printf '[recovery] previous-boot Thunderbolt units and tag follow\n'
        journalctl -b -1 -o short-monotonic --no-pager \
            -t silverletter-thunderbolt 2>&1 || true
        for unit in \
            silverletter-thunderbolt-hotplug.service \
            silverletter-thunderbolt-disconnect.service \
            silverletter-thunderbolt-sleep.service \
            silverletter-thunderbolt-powerdown.service
        do
            journalctl -b -1 -o short-monotonic --no-pager -u "$unit" 2>&1 || true
        done
        for pstore_file in /sys/fs/pstore/*; do
            [[ -f "$pstore_file" ]] || continue
            printf '[recovery] pstore_file=%s\n' "$pstore_file"
            head -c 1048576 "$pstore_file" 2>&1 || true
            printf '\n'
        done
        printf '[recovery] end\n'
    } >> "$previous"
    RECOVERED_LOG="$previous"
}

recover_previous_run
touch "$LOG_FILE"
chmod 0644 "$LOG_FILE"
printf '%s\n' "$LOG_FILE" > "$LAST_LOG_FILE"
chmod 0644 "$LAST_LOG_FILE"

umask 077
config_tmp="$(mktemp "${STATE_DIR}/thunderbolt-debug.conf.XXXXXX")"
{
    printf 'TB_DEBUG_RUN_ID=%q\n' "$RUN_ID"
} > "$config_tmp"
mv -f "$config_tmp" "$CONFIG_FILE"
chmod 0600 "$CONFIG_FILE"

exec > >(tee -a "$LOG_FILE") 2>&1

COLLECTOR_PIDS=()
RUN_FINISHED=0

sync_log() {
    sync -f "$LOG_FILE" 2>/dev/null || true
}

event() {
    printf '[debug] realtime=%s monotonic=%s run=%s %s\n' \
        "$(date --iso-8601=ns)" "$(awk '{print $1}' /proc/uptime)" "$RUN_ID" "$*"
    sync_log
}

desktop_user() {
    local session

    if [[ -n "${SUDO_USER:-}" && "$SUDO_USER" != "root" ]]; then
        printf '%s\n' "$SUDO_USER"
        return 0
    fi
    session="$(loginctl list-sessions --no-legend 2>/dev/null | awk '$3 != "root" {print $1; exit}')"
    [[ -n "$session" ]] || return 1
    loginctl show-session "$session" -p Name --value 2>/dev/null
}

notify_user() {
    local message="$1" user uid

    command -v notify-send >/dev/null 2>&1 || return 0
    command -v runuser >/dev/null 2>&1 || return 0
    user="$(desktop_user 2>/dev/null)" || return 0
    uid="$(id -u "$user")"
    runuser -u "$user" -- env \
        DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${uid}/bus" \
        notify-send --app-name=Silverletter --urgency=normal \
        'Thunderbolt diagnostic' "$message" >/dev/null 2>&1 || true
}

prompt_action() {
    local step="$1" message="$2"

    event "user-instruction step=$step message=$(printf '%q' "$message")"
    notify_user "$message"
    printf '\n%s\n' "$message"
    read -r -p 'Press Enter after completing this step... '
    event "user-acknowledged step=$step"
}

external_device_present() {
    local path real_path

    for path in /sys/bus/pci/devices/*; do
        [[ -e "$path" ]] || continue
        real_path="$(readlink -f "$path" 2>/dev/null)" || continue
        [[ "$real_path" == *"/0000:06:03.0/"* ]] && return 0
    done
    return 1
}

falcon_ridge_present() {
    local bdf

    for bdf in 05:00.0 06:00.0 06:03.0 06:04.0 06:05.0 06:06.0 07:00.0; do
        [[ -e "/sys/bus/pci/devices/0000:${bdf}" ]] && return 0
    done
    return 1
}

state_signature() {
    local bdf path real_path marker=absent established=absent powering=absent
    local unsafe_replug=absent external="" internal="" modules=""

    [[ -e "${STATE_DIR}/thunderbolt-enabled" ]] && marker=present
    [[ -e "${STATE_DIR}/thunderbolt-established" ]] && established=present
    [[ -e "${STATE_DIR}/thunderbolt-powering-down" ]] && powering=present
    [[ -e "${STATE_DIR}/thunderbolt-replug-during-powerdown" ]] && unsafe_replug=present
    for bdf in 05:00.0 06:00.0 06:03.0 06:04.0 06:05.0 06:06.0 07:00.0; do
        [[ -e "/sys/bus/pci/devices/0000:${bdf}" ]] && internal+="${internal:+,}${bdf}"
    done
    for path in /sys/bus/pci/devices/*; do
        [[ -e "$path" ]] || continue
        real_path="$(readlink -f "$path" 2>/dev/null)" || continue
        if [[ "$real_path" == *"/0000:06:03.0/"* ]]; then
            external+="${external:+,}$(basename "$path")"
        fi
    done
    modules="$(awk '$1 ~ /^thunderbolt/ {printf "%s%s", separator, $1; separator=","}' /proc/modules)"
    printf 'marker=%s established=%s powering_down=%s unsafe_replug=%s internal=%s external=%s modules=%s' \
        "$marker" "$established" "$powering" "$unsafe_replug" \
        "${internal:-none}" "${external:-none}" "${modules:-none}"
}

monitor_topology() {
    local previous="" current

    while true; do
        current="$(state_signature)"
        if [[ "$current" != "$previous" ]]; then
            printf '[state] realtime=%s monotonic=%s %s\n' \
                "$(date --iso-8601=ns)" "$(awk '{print $1}' /proc/uptime)" "$current"
            previous="$current"
        fi
        sleep 0.25
    done
}

start_collectors() {
    (
        stdbuf -oL -eL journalctl -b -k -f -n 0 -o short-monotonic --no-pager 2>&1 |
            sed -u 's/^/[kernel] /'
    ) &
    COLLECTOR_PIDS+=("$!")

    (
        stdbuf -oL -eL journalctl -b -f -n 0 -o short-monotonic --no-pager 2>&1 |
            grep --line-buffered -Ei 'silverletter-thunderbolt|thunderbolt|systemd-sleep|suspend|resume|pcie|pci ' |
            sed -u 's/^/[journal] /'
    ) &
    COLLECTOR_PIDS+=("$!")

    (
        stdbuf -oL -eL udevadm monitor --kernel --udev --subsystem-match=pci 2>&1 |
            sed -u 's/^/[udev] /'
    ) &
    COLLECTOR_PIDS+=("$!")

    monitor_topology &
    COLLECTOR_PIDS+=("$!")

    (
        while true; do
            sleep 2
            sync_log
        done
    ) &
    COLLECTOR_PIDS+=("$!")
}

stop_collectors() {
    local pid

    for pid in "${COLLECTOR_PIDS[@]:-}"; do
        kill "$pid" 2>/dev/null || true
        pkill -P "$pid" 2>/dev/null || true
    done
    wait 2>/dev/null || true
}

snapshot() {
    local label="$1" path real_path bdf attribute value

    event "snapshot stage=$label begin"
    printf '[snapshot] state %s\n' "$(state_signature)"
    printf '[snapshot] cmdline %s\n' "$(< /proc/cmdline)"
    printf '[snapshot] preset connect_timeout=%s connection_hold=%s disconnect_timeout=%s backend_timing=production-defaults\n' \
        "$CONNECT_TIMEOUT" "$CONNECTION_HOLD" "$DISCONNECT_TIMEOUT"
    timeout 5 systemctl show --no-pager \
        -p Id -p ActiveState -p SubState -p Result -p MainPID -p ExecMainStatus \
        silverletter-thunderbolt-hotplug.service \
        silverletter-thunderbolt-disconnect.service \
        silverletter-thunderbolt-sleep.service \
        silverletter-thunderbolt-powerdown.service 2>&1 |
        sed 's/^/[snapshot] systemd /' || true
    ps -eo pid,ppid,stat,wchan:32,etimes,comm,args | \
        awk '/\/usr\/libexec\/(silverletter-thunderbolt-control|tb-powerdown\.sh)/ {
            print "[snapshot] backend-process " $0
        }' || true

    for path in /sys/bus/pci/devices/*; do
        [[ -e "$path" ]] || continue
        real_path="$(readlink -f "$path" 2>/dev/null)" || continue
        bdf="$(basename "$path")"
        if [[ "$real_path" != *"/0000:05:00.0"* ]]; then
            continue
        fi
        printf '[snapshot] pci bdf=%s path=%s' "$bdf" "$real_path"
        for attribute in vendor device class power/control power/runtime_status power/runtime_active_time power/runtime_suspended_time; do
            if [[ -r "${path}/${attribute}" ]]; then
                value="$(< "${path}/${attribute}")" || value=unreadable
                printf ' %s=%s' "${attribute//\//_}" "$value"
            fi
        done
        printf '\n'
    done
    event "snapshot stage=$label end"
}

wait_for_external_present() {
    local timeout_seconds="$1" label="$2" deadline last_report=$SECONDS

    deadline=$((SECONDS + timeout_seconds))
    while (( SECONDS <= deadline )); do
        if external_device_present; then
            event "wait result=success condition=external-present label=$label"
            return 0
        fi
        if (( SECONDS - last_report >= 5 )); then
            event "wait progress condition=external-present label=$label state=$(state_signature)"
            last_report=$SECONDS
        fi
        sleep 0.5
    done
    event "wait result=timeout condition=external-present label=$label seconds=$timeout_seconds"
    return 1
}

wait_for_external_absent() {
    local timeout_seconds="$1" label="$2" deadline

    deadline=$((SECONDS + timeout_seconds))
    while (( SECONDS <= deadline )); do
        if ! external_device_present; then
            event "wait result=success condition=external-absent label=$label"
            return 0
        fi
        sleep 0.5
    done
    event "wait result=timeout condition=external-absent label=$label seconds=$timeout_seconds"
    return 1
}

wait_for_powered_down() {
    local timeout_seconds="$1" label="$2" deadline last_report=$SECONDS

    deadline=$((SECONDS + timeout_seconds))
    while (( SECONDS <= deadline )); do
        if ! falcon_ridge_present; then
            event "wait result=success condition=powered-down label=$label"
            return 0
        fi
        if (( SECONDS - last_report >= 5 )); then
            event "wait progress condition=powered-down label=$label state=$(state_signature)"
            last_report=$SECONDS
        fi
        sleep 0.5
    done
    event "wait result=timeout condition=powered-down label=$label seconds=$timeout_seconds"
    return 1
}

stop_test() {
    local reason="$1"

    snapshot "stopped-${reason}"
    event "result=stopped reason=$reason recommendation=reboot-before-further-hotplug"
    notify_user 'Diagnostic stopped. Disconnect the adapter and reboot before another test.'
    RUN_FINISHED=1
    printf '\nDiagnostic stopped. Disconnect the adapter and reboot before another test.\nLog: %s\n' "$LOG_FILE"
    exit 1
}

connect_step() {
    local label="$1"

    prompt_action "$label" 'Connect the Thunderbolt adapter now.'
    if ! wait_for_external_present "$CONNECT_TIMEOUT" "$label"; then
        stop_test "${label}-not-detected"
    fi
    snapshot "${label}-detected"
    event "hold stage=$label seconds=$CONNECTION_HOLD purpose=connection-stability"
    sleep "$CONNECTION_HOLD"
    if ! external_device_present; then
        event "connection stage=$label result=lost-during-hold"
        if ! wait_for_external_present "$CONNECT_TIMEOUT" "${label}-recovery"; then
            stop_test "${label}-did-not-recover"
        fi
    fi
    snapshot "${label}-stable"
}

disconnect_step() {
    local label="$1"

    prompt_action "$label" 'Disconnect the Thunderbolt adapter now. Do not reconnect until instructed.'
    wait_for_external_absent 45 "$label" || stop_test "${label}-external-still-present"
    snapshot "${label}-external-gone"
    if ! wait_for_powered_down "$DISCONNECT_TIMEOUT" "$label"; then
        stop_test "${label}-powerdown-timeout"
    fi
    snapshot "${label}-powered-down"
}

suspend_test_ready() {
    [[ -e "${STATE_DIR}/thunderbolt-enabled" ]] &&
        [[ -e "${STATE_DIR}/thunderbolt-established" ]] &&
        [[ ! -e "${STATE_DIR}/thunderbolt-powering-down" ]] &&
        [[ ! -e "${STATE_DIR}/thunderbolt-replug-during-powerdown" ]] &&
        external_device_present &&
        grep -q '^thunderbolt ' /proc/modules
}

suspend_step() {
    local suspend_since suspend_journal

    if ! suspend_test_ready; then
        event "suspend-test result=refused reason=connection-not-cleanly-established state=$(state_signature)"
        stop_test suspend-precondition-failed
    fi

    prompt_action suspend-ready 'Leave the adapter connected. Press Enter here when ready for the suspend test.'
    suspend_since="$(date --iso-8601=seconds)"
    event 'user-instruction step=suspend-now message=Leave_adapter_connected_suspend_for_30_seconds_then_resume'
    notify_user 'Leave the adapter connected. Suspend for 30 seconds, then resume.'
    printf '\nLeave the adapter connected. Suspend for 30 seconds, then resume.\n'
    read -r -p 'After the computer resumes, return here and press Enter... '
    event 'user-acknowledged step=resume-returned'
    sleep 5

    suspend_journal="$(journalctl -b -k --since "$suspend_since" --no-pager 2>/dev/null || true)"
    if ! grep -q 'PM: suspend entry' <<< "$suspend_journal"; then
        snapshot suspend-not-entered
        event 'suspend-test result=failed reason=kernel-suspend-entry-not-observed'
        stop_test suspend-not-entered
    fi
    if ! grep -q 'PM: suspend exit' <<< "$suspend_journal"; then
        snapshot suspend-exit-not-observed
        event 'suspend-test result=failed reason=kernel-suspend-exit-not-observed'
        stop_test suspend-exit-not-observed
    fi

    event 'suspend-test stage=kernel-suspend-cycle-observed'
    snapshot post-resume
    if external_device_present; then
        event 'suspend-test result=external-device-present-after-resume'
    else
        event 'suspend-test result=external-device-absent-after-resume waiting_for_recovery=yes'
        wait_for_external_present 60 resume-recovery || true
        snapshot post-resume-recovery-window
    fi
}

cleanup() {
    local status=$?

    stop_collectors
    if [[ -r "$CONFIG_FILE" ]] && grep -Fq "TB_DEBUG_RUN_ID=${RUN_ID}" "$CONFIG_FILE"; then
        rm -f "$CONFIG_FILE"
    fi
    sync_log
    if (( RUN_FINISHED == 0 )); then
        event "result=interrupted exit_status=$status recovery_on_next_run=yes"
    fi
}
trap cleanup EXIT INT TERM

event "action=start preset=$PRESET scenario=$SCENARIO log=$LOG_FILE"
printf 'Silverletter Thunderbolt diagnostic\nPreset: %s  Scenario: %s\nLog: %s\n\n' \
    "$PRESET" "$SCENARIO" "$LOG_FILE"
printf 'Observation: connect timeout %ss, stability hold %ss, disconnect timeout %ss.\n' \
    "$CONNECT_TIMEOUT" "$CONNECTION_HOLD" "$DISCONNECT_TIMEOUT"
printf 'The preset does not change activation or PCI-removal timing.\n'
printf 'This test deliberately avoids lspci while PCI removal may be active.\n'
printf 'If the machine freezes or panics, hard reboot; the next debug run will append previous-boot evidence to this log.\n'
if [[ -n "$RECOVERED_LOG" ]]; then
    printf 'Recovered evidence from the preceding interrupted run into:\n%s\n' "$RECOVERED_LOG"
fi
start_collectors
snapshot initial

if external_device_present; then
    prompt_action preflight-disconnect 'Disconnect the Thunderbolt adapter before beginning.'
    wait_for_external_absent 45 preflight || stop_test preflight-external-still-present
fi

if falcon_ridge_present; then
    event 'preflight stage=waiting-for-existing-powerdown seconds=30'
    wait_for_powered_down 30 preflight-existing || true
fi

if falcon_ridge_present; then
    event 'preflight result=failed reason=thunderbolt-hierarchy-present passive_debug_no_teardown=yes'
    stop_test preflight-not-powered-down
fi

case "$SCENARIO" in
    hotplug)
        connect_step connect-1
        disconnect_step disconnect-1
        connect_step reconnect-1
        disconnect_step disconnect-2
        ;;
    suspend)
        connect_step connect-before-suspend
        suspend_step
        disconnect_step disconnect-after-resume
        ;;
    all)
        connect_step connect-1
        disconnect_step disconnect-1
        connect_step connect-before-suspend
        suspend_step
        disconnect_step disconnect-after-resume
        ;;
esac

snapshot final
event 'result=completed'
RUN_FINISHED=1
notify_user 'Thunderbolt diagnostic completed. The log is ready.'
printf '\nDiagnostic complete. Paste this file for review:\n%s\n' "$LOG_FILE"
