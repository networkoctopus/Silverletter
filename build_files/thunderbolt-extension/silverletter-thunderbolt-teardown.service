[Unit]
Description=Quiesce and restore Thunderbolt across system sleep
DefaultDependencies=no
Before=sleep.target
StopWhenUnneeded=yes

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/libexec/silverletter-thunderbolt-control prepare-suspend
ExecStop=/usr/libexec/silverletter-thunderbolt-control resume
TimeoutStartSec=60
TimeoutStopSec=60

[Install]
RequiredBy=sleep.target
